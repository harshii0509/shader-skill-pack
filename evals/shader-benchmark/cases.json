    {
      "id": "stylization_platform_combo",
      "prompt": "I want a Kuwahara painterly filter applied as a post-processing pass — does it matter whether I write it in WebGPU TSL or classic WebGL?",
      "expected_primary_lane": "shader-stylization",
      "expected_first_references": [
        "shader-stylization/references/stylized-recipes.md"
      ],
      "must_mention": ["kuwahara", "painterly", "post-processing"],
      "must_avoid": ["caustics", "scattering", "fbm"]
    },
    {
      "id": "volume_physical_scattering",
      "prompt": "Explain Mie and Rayleigh scattering and how Beer-Lambert attenuation applies to a physically-based sky shader.",
      "expected_primary_lane": "shader-volumetrics",
      "expected_first_references": [
        "shader-volumetrics/references/atmosphere-and-volume.md"
      ],
      "must_mention": ["mie", "rayleigh", "beer-lambert", "scattering"],
      "must_avoid": ["halftone", "fresnel", "compute"]
    },
    {
      "id": "router_painterly_cloudscape",
      "prompt": "I want a painterly dreamy cloudscape where the final image has heavy Kuwahara oil-brush strokes applied in a post-processing pass.",
      "expected_primary_lane": "shader-stylization",
      "expected_first_references": [
        "shader-stylization/references/stylized-recipes.md"
      ],
      "must_mention": ["painterly", "kuwahara", "post-processing"],
      "must_avoid": ["caustics", "tsl", "fresnel"]
    }
  ]
