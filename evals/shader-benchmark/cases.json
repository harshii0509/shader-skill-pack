      "prompt": "Add depth-based fog so geometry fades out smoothly into the background colour at distance.",
      "expected_primary_lane": "shader-volumetrics",
      "expected_first_references": [
        "shader-volumetrics/references/atmosphere-and-volume.md"
      ],
      "must_mention": ["fog", "depth", "volumetric"],
      "must_avoid": ["halftone", "fresnel", "compute"]
    },
    {
      "id": "platforms_drei_postprocessing",
      "prompt": "How do I wire up @react-three/drei helpers and @react-three/postprocessing EffectComposer in my R3F scene?",
      "expected_primary_lane": "shader-platforms",
      "expected_first_references": [
        "shader-platforms/references/platform-patterns.md"
      ],
      "must_mention": ["drei", "postprocessing", "react three fiber"],
      "must_avoid": ["halftone", "caustics", "scattering"]
    },
    {
      "id": "lighting_water_refraction",
      "prompt": "I want a water surface shader with normal-map driven ripples and glass-like refraction to the geometry below.",
      "expected_primary_lane": "shader-lighting",
      "expected_first_references": [
        "shader-lighting/references/light-material-recipes.md"
      ],
      "must_mention": ["refraction", "normals", "fresnel"],
      "must_avoid": ["clouds", "tsl", "halftone"]
